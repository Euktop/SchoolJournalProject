<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main_main"
    app:startDestination="@id/mainMenuFragment">

    <!-- Главное меню -->
    <fragment
        android:id="@+id/mainMenuFragment"
        android:name="stud.euktop.schooljournal.presentation.main.MainMenuFragment"
        android:label="Главное меню"
        tools:layout="@layout/fragment_main_menu" />

    <!-- Учительская цепочка (уже было) -->
    <fragment
        android:id="@+id/teacherClassesFragment"
        android:name="stud.euktop.schooljournal.presentation.main.teacher.teacherClass.TeacherClassesFragment"
        android:label="Мои классы"
        tools:layout="@layout/fragment_teacher_classes" />

    <fragment
        android:id="@+id/teacherLessonsFragment"
        android:name="stud.euktop.schooljournal.presentation.main.teacher.teacherLessons.TeacherLessonsFragment"
        android:label="Уроки"
        tools:layout="@layout/fragment_teacher_lessons">
        <argument
            android:name="classId"
            app:argType="integer" />
        <argument
            android:name="subjectId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/lessonMarksFragment"
        android:name="stud.euktop.schooljournal.presentation.main.teacher.lessonMarks.LessonMarksFragment"
        android:label="Оценки за урок"
        tools:layout="@layout/fragment_lesson_marks">
        <argument
            android:name="lessonId"
            app:argType="integer" />
    </fragment>

    <!-- Студенческая цепочка -->
    <fragment
        android:id="@+id/studentSubjectsFragment"
        android:name="stud.euktop.schooljournal.presentation.main.student.studentSubjects.StudentSubjectsFragment"
        android:label="Предметы ученика"
        tools:layout="@layout/fragment_student_subjects" />

    <fragment
        android:id="@+id/studentSubjectDetailFragment"
        android:name="stud.euktop.schooljournal.presentation.main.student.studentSubjectDetail.StudentSubjectDetailFragment"
        android:label="Детали предмета"
        tools:layout="@layout/fragment_student_subject_detail" />

    <!-- Административная панель -->
    <fragment
        android:id="@+id/adminPanelFragment"
        android:name="stud.euktop.schooljournal.presentation.main.admin.panel.AdminPanelFragment"
        android:label="Админ панель"
        tools:layout="@layout/fragment_admin_panel" />

    <!-- Профиль -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="stud.euktop.schooljournal.presentation.main.profile.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile" />

</navigation>