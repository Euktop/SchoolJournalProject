<?xml version="1.0" encoding="utf-8"?><!-- res/layout/fragment_teacher_homework_list.xml -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:ignore="UselessParent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="Домашние задания" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddHomework"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_margin="16dp"
            android:contentDescription="@string/add_homework"
            android:src="@android:drawable/ic_menu_add"
            app:tint="@color/color_text_on_accent"
            android:backgroundTint="@color/color_accent"/>

        <stud.euktop.uikit.components.recycler.SchJStatefulRecyclerView
            android:id="@+id/rvHomeworkList"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>
</FrameLayout>