<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary"
    android:orientation="vertical"
    tools:context=".presentation.main.student.dashboard.StudentDashboardFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/color_accent"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvWelcomeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hello_student"
                        android:textAppearance="@style/TextAppearance.SchJ.Title1.Bold"
                        android:textColor="@color/color_text_on_accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="24dp"
                        android:alpha="0.9"
                        android:text="@string/good_results"
                        android:textAppearance="@style/TextAppearance.SchJ.Text.Regular"
                        android:textColor="@color/color_text_on_accent" />

                    <!-- Stats Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- New Homeworks -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_overlay"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:text="@string/new_homeworks"
                                android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                                android:textColor="@color/color_text_on_accent" />

                            <TextView
                                android:id="@+id/tvNewHomeworksCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="3"
                                android:textAppearance="@style/TextAppearance.SchJ.Title2.Bold"
                                android:textColor="@color/color_text_on_accent" />
                        </LinearLayout>

                        <!-- Average Mark -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_overlay"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:text="@string/average_mark"
                                android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                                android:textColor="@color/color_text_on_accent" />

                            <TextView
                                android:id="@+id/tvAverageMark"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="4.8"
                                android:textAppearance="@style/TextAppearance.SchJ.Title2.Bold"
                                android:textColor="@color/color_text_on_accent" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bento Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:useDefaultMargins="true">

                <!-- Schedule -->
                <LinearLayout
                    android:id="@+id/btnSchedule"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill"
                    android:background="@drawable/bg_bento_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_circle_secondary">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_calendar_month"
                            app:tint="@color/color_text_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/schedule"
                        android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/tvScheduleSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/lessons_today"
                        android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <!-- My Subjects -->
                <LinearLayout
                    android:id="@+id/btnSubjects"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill"
                    android:background="@drawable/bg_bento_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_circle_tertiary">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_book"
                            app:tint="@color/color_text_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/my_subjects"
                        android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/tvSubjectsSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/subjects_count"
                        android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <!-- Marks Details -->
                <LinearLayout
                    android:id="@+id/btnMarks"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill"
                    android:background="@drawable/bg_bento_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_circle_error">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_grade"
                            app:tint="@color/color_text_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/marks_details"
                        android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/tvMarksSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/updated_hours_ago"
                        android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <!-- Homework -->
                <LinearLayout
                    android:id="@+id/btnHomework"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill"
                    android:background="@drawable/bg_bento_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_circle_primary">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_assignment"
                            app:tint="@color/color_text_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/homeworks"
                        android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/tvHomeworkSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/homeworks_not_submitted"
                        android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <!-- Analytics -->
                <LinearLayout
                    android:id="@+id/btnAnalytics"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill"
                    android:background="@drawable/bg_bento_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_circle_analytics">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_analytics"
                            app:tint="@color/color_text_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/analytics"
                        android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/performance_stats"
                        android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_gravity="fill"
                    android:background="@drawable/bg_bento_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_circle_settings">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/color_text_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings"
                        android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/account_privacy"
                        android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>
            </GridLayout>

            <!-- Next Lesson Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNextLesson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/color_bg_tertiary"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/next_lesson"
                            android:textAppearance="@style/TextAppearance.SchJ.Title2.SemiBold"
                            android:textColor="@color/color_text_primary" />

                        <TextView
                            android:id="@+id/tvTimeBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_next_lesson_badge"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="@string/in_15_min"
                            android:textAppearance="@style/TextAppearance.SchJ.Caption2.Bold"
                            android:textColor="@color/color_text_accent" />
                    </LinearLayout>

                    <!-- Lesson Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_next_lesson_icon">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_functions"
                                app:tint="@color/color_text_accent" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvLessonName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/higher_math"
                                android:textAppearance="@style/TextAppearance.SchJ.Headline.Bold"
                                android:textColor="@color/color_text_primary" />

                            <TextView
                                android:id="@+id/tvLessonDetails"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/room_and_teacher"
                                android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                                android:textColor="@color/color_text_secondary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>