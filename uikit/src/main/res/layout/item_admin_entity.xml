<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvEntityName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textAppearance="@style/TextAppearance.SchJ.Text.Medium"
        android:textColor="@color/color_text_primary" />

    <stud.euktop.uikit.components.button.SchJButton
        android:id="@+id/btnEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/short_change"
        app:schJButtonType="CHIPS"
        app:schJButtonClass="PRIMARY"
        android:layout_marginEnd="8dp" />

    <stud.euktop.uikit.components.button.SchJButton
        android:id="@+id/btnDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/short_delete"
        app:schJButtonType="CHIPS"
        app:schJButtonClass="PRIMARY" />
</LinearLayout>