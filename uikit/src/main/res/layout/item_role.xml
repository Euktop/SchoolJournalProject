<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRole"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/color_stroke_default"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Иконка роли -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_role_card_unselected">

            <ImageView
                android:id="@+id/ivRoleIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                app:tint="@color/color_text_primary"
                tools:src="@drawable/ic_school" />
        </FrameLayout>

        <!-- Текст роли -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
                android:textColor="@color/color_text_primary"
                tools:text="Учитель" />

            <TextView
                android:id="@+id/tvRoleDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                android:textColor="@color/color_text_secondary"
                tools:text="Управление классами и оценками" />
        </LinearLayout>

        <!-- Галочка (видна только для выбранной роли) -->
        <ImageView
            android:id="@+id/ivCheck"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_check_circle"
            android:visibility="invisible"
            tools:visibility="visible" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>