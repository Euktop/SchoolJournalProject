<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    app:cardCornerRadius="@dimen/corner_base"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/color_white"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_lesson_topic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.SchJ.Title3.SemiBold"
            android:textColor="@color/color_text_primary"
            tools:text="Квадратные уравнения" />

        <TextView
            android:id="@+id/tv_lesson_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.SchJ.Text.Regular"
            android:textColor="@color/color_text_secondary"
            tools:text="28.04.2026" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_lesson_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                android:textColor="@color/color_text_secondary"
                tools:text="09:00 - 09:45" />

            <TextView
                android:id="@+id/tv_lesson_room"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textAppearance="@style/TextAppearance.SchJ.Caption.Regular"
                android:textColor="@color/color_text_secondary"
                tools:text="Каб. 42" />

            <TextView
                android:id="@+id/tv_lesson_teacher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.SchJ.Caption.Medium"
                android:textColor="@color/color_text_accent"
                tools:text="Иванова А.А." />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>