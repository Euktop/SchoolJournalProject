<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/color_bg_secondary"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_stroke_default"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Иконка типа файла -->
        <FrameLayout
            android:id="@+id/fileIconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_file_icon">

            <ImageView
                android:id="@+id/ivFileType"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_description"
                app:tint="@color/color_text_on_accent" />
        </FrameLayout>

        <!-- Информация о файле -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.SchJ.Text.Medium"
                android:textColor="@color/color_text_primary"
                tools:text="work_sheet_v1.pdf" />

            <TextView
                android:id="@+id/tvFileSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.SchJ.Caption2.Regular"
                android:textColor="@color/color_text_secondary"
                tools:text="2.4 MB • PDF" />
        </LinearLayout>

        <!-- Кнопка действия (скачать/удалить) -->
        <ImageView
            android:id="@+id/btnAction"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/ic_download"
            app:tint="@color/color_text_accent" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>